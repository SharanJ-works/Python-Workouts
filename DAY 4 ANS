print("Second Largest:", a[-2])
Tuple

1. Count how many times an element occurs in a tuple.

t = (1, 2, 3, 2, 4, 2)
print(t.count(2))

2. Reverse a tuple using slicing.

t = (1, 2, 3, 4)
print(t[::-1])

3. Unpack a tuple containing name, age, and city.

t = ("Sharan", 20, "Coimbatore")
name, age, city = t
print(name, age, city)

4. Iterate through a tuple and print all elements.

t = (10, 20, 30)

for i in t:
    print(i)

5. Check whether an element exists in a tuple.

t = (1, 2, 3, 4)
print(3 in t)

6. Convert a tuple into a list and vice versa.

t = (1, 2, 3)
l = list(t)
t = tuple(l)
print(l)
print(t)
Set

1. Check whether an element exists in a set.

s = {1, 2, 3, 4}
print(3 in s)

2. Find the union of two sets.

a = {1, 2, 3}
b = {3, 4, 5}
print(a | b)

3. Find the intersection of two sets.

a = {1, 2, 3}
b = {3, 4, 5}
print(a & b)

4. Find the difference between two sets.

a = {1, 2, 3}
b = {3, 4, 5}
print(a - b)

5. Find the symmetric difference.

a = {1, 2, 3}
b = {3, 4, 5}
print(a ^ b)

6. Remove duplicates from a list using sets.

a = [1, 2, 2, 3, 4, 4]
print(list(set(a)))

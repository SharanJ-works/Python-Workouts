1. Create a Circle class and calculate area.
class Circle:
    def __init__(self, r):
        self.r = r
    def area(self):
        print("Area =", 3.14 * self.r * self.r)
c = Circle(5)
c.area()

2. Create a Book class with title and author and display details.
class Book:
    def __init__(self, title, author):
        self.title = title
        self.author = author

    def display(self):
        print("Title:", self.title)
        print("Author:", self.author)
b = Book("Python", "Guido")
b.display()

3. Create a Person class and a Student class that inherits from it.
class Person:
    def __init__(self, name):
        self.name = name
class Student(Person):
    def display(self):
        print("Name:", self.name)
s = Student("Sharan")
s.display()

4. Create a School class with a class variable school_name and display it using a class method.
class School:
    school_name = "ABC School"
    def display(cls):
        print(cls.school_name)
School.display()

5. Rectangle Area

class Rectangle:
    def __init__(self, length, breadth):
        self.length = length
        self.breadth = breadth

    def area(self):
        print("Area =", self.length * self.breadth)
r = Rectangle(10, 5)
r.area()

6. Library Management System using Class, Object & Instance Methods

class Library:
    def __init__(self, book):
        self.book = book
    def issue(self):
        print(self.book, "issued")
    def return_book(self):
        print(self.book, "returned")
l = Library("Python")
l.issue()
l.return_book()
